APP_NAME=JuegaNet
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-backend.railway.app
APP_PORT=8080

FRONTEND_URL=https://tu-frontend.vercel.app

SANCTUM_STATEFUL_DOMAINS=tu-frontend.vercel.app
SESSION_DOMAIN=railway.app

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="0.0.0.0"
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_PORT=8081

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Railway bloquea SMTP saliente (Gmail) → opciones:
# 1) Railway SendGrid plugin (recomendado): instalar plugin, pone MAIL_MAILER=sendgrid
# 2) Mailgun: Railway tiene plugin
# 3) MAIL_MAILER=log (default): emails se ven en Railway Logs
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@jueganet.online
MAIL_FROM_NAME="JuegaNet"

# Para SendGrid Railway plugin (instalar plugin en Railway Dashboard):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.tu_api_key_aqui
# MAIL_ENCRYPTION=tls

# Para Gmail SMTP (solo si Railway lo permite):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu@email.com
# MAIL_PASSWORD=tu_contraseña_de_aplicacion
# MAIL_ENCRYPTION=tls
