APP_NAME=JuegaNet
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-backend.railway.app
APP_PORT=8080

FRONTEND_URL=https://tu-frontend.vercel.app

SANCTUM_STATEFUL_DOMAINS=tu-frontend.vercel.app
SESSION_DOMAIN=railway.app

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="0.0.0.0"
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_PORT=8081

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=file

RESEND_API_KEY=

# Railway bloquea SMTP saliente → usar HTTP API (Resend recomendado, tier gratis)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@jueganet.online
MAIL_FROM_NAME="JuegaNet"

# Resend (recomendado): registrarse en resend.com, crear API Key, poner:
# MAIL_MAILER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxx
# MAIL_FROM_ADDRESS=onboarding@resend.dev  (o dominio propio verificado)

# Mailgun: registrarse en mailgun.com, dominio sandbox, poner:
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=sandbox-xxx.mailgun.org
# MAILGUN_SECRET=key-xxx
# MAIL_FROM_ADDRESS=postmaster@sandbox-xxx.mailgun.org

# Postmark: registrarse en postmarkapp.com, Server API token, poner:
# MAIL_MAILER=postmark
# POSTMARK_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Amazon SES:
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_DEFAULT_REGION=us-east-1
